rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      // owner can do anything
      allow write: if request.auth.uid == userId;
      // others can only update these four fields (for partner invite/accept/disconnect)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['listId', 'partnerEmail', 'pendingInviteFrom', 'pendingInviteTo']);
    }

    match /lists/{listId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;

      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }

      match /products/{productId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }
    }
  }
}
