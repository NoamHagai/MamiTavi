// firestore.rules
// העתק את הכללים האלה ל-Firestore Rules בקונסול של Firebase

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can only read/write own document
    match /users/{userId} {
      allow read: if request.auth != null;  // אחרים צריכים לחפש לפי אימייל
      allow write: if request.auth.uid == userId;
    }

    // Lists: only list members can read/write
    match /lists/{listId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.members;

      allow create: if request.auth != null;

      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }
    }
  }
}
