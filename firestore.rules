rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read/write user profiles
    // (needed for invite flow cross-user writes)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /lists/{listId} {
      allow read, write: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      // Allow joining an existing list (user adding themselves as member)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        && request.auth.uid in request.resource.data.members;

      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }
      match /products/{productId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }
    }
  }
}
